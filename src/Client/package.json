  "scripts": {
    "preinstall": "yarn dedupe-browserslist-packages",
    "build": "webpack --config webpack.development.mjs",
    "production": "webpack --config webpack.production.mjs",
    "start": "webpack serve --config webpack.development.mjs --open",
    "typecheck": "tsc --project jsconfig.json --noEmit --pretty false | node -e \"const errors = require('fs').readFileSync(0, 'utf-8').replace(/^node_modules.*\\r?\\n(?: .*\\r?\\n?)*/gm, '').trim(); if (errors) { console.log(errors); process.exit(1); }\"",
    "dedupe-browserslist-packages": "yarn dedupe caniuse-lite baseline-browser-mapping --strategy highest --mode=skip-build",
    "update-yarn": "corepack up",
    "ncu": "yarn dlx npm-check-updates",
    "update-transitive": "yarn dlx rimraf yarn.lock && yarn install",
    "eslint-inspector": "yarn dlx @eslint/config-inspector"
  },
  "engines": {
    "yarn": "4.x",
    "node": "24.x || 26.x"
  },
